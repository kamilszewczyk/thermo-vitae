---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const pages = await getCollection("pages");
	return pages
		.filter(page => (page.data.slug ?? page.id.replace(/\.mdoc$/, '')) !== 'home')
		.map((page) => ({
			params: { slug: page.data.slug ?? page.id.replace(/\.mdoc$/, "") },
			props: { page },
		}));
}

const allPages = await getCollection('pages');
const { page: staticPage } = Astro.props as {
	page?: (typeof allPages)[number];
};

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam;

const page =
	staticPage ??
	allPages.find((item) => (item.data.slug ?? item.id.replace(/\.mdoc$/, '')) === slug);

if (!page) {
	throw Astro.redirect('/');
}

// Astro 5+: render is a top-level function, not a method on the entry
const { Content } = await render(page);
---

<BaseLayout title={page.data.title}>
	<div class="mdoc-content mdoc-prose prose max-w-none prose-zinc lg:prose-lg prose-headings:text-text-primary prose-p:text-text-primary prose-li:text-text-primary prose-strong:text-text-primary prose-a:text-brand-forest-green hover:prose-a:text-brand-natural-green">
		<Content />
	</div>
</BaseLayout>