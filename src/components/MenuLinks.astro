---
// Reusable menu links component
// Props:
// - class: container classes applied to the <nav>
// - linkClass: classes applied to each <a> link
const { class: className = "", linkClass = "" } = Astro.props;
---
<nav class={className}>
  <a href="#uslugi" class={linkClass}>Usługi</a>
  <a href="#proces" class={linkClass}>Jak działamy</a>
  <a href="#realizacje" class={linkClass}>Realizacje</a>
  <a href="#kontakt" class={linkClass}>Kontakt</a>
</nav>
