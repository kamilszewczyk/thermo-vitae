---
import { Icon } from 'astro-icon/components'
import {getEntry} from "astro:content";

const informationEntry = await getEntry("information", "information");
const information = informationEntry?.data;

const phone = information?.phone ?? "+48 123 456 789";
const phoneHref = `tel:${phone.replace(/\s+/g, '')}`;
const address = information?.address ?? "ul. Przykładowa 123\n00-001 Warszawa";
const opening_hours = information?.opening_hours ?? "Poniedziałek - Piątek: 8:00 - 18:00\nSobota: 9:00 - 14:00";
const email = information?.email ?? "kontakt@thermovitae.pl";
---
<section class="py-16 lg:py-24 bg-background-gray" id="kontakt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap md:flex-nowrap gap-12">
      <!-- Right side - Contact info -->
      <div class="grow">
        <div class="bg-card rounded-2xl p-8 shadow-sm">
          <h3 class="text-2xl font-bold mb-6 text-text-primary">
            Dane kontaktowe
          </h3>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 bg-brand-natural-green">
                <Icon name="lucide:phone" width="20" height="20" class="text-white" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold mb-1 text-text-primary">Telefon</p>
                <a href={phoneHref} class="text-text-body hover:text-brand-forest-green transition-colors">{phone}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 bg-brand-natural-green">
                <Icon name="lucide:mail" width="20" height="20" class="text-white" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold mb-1 text-text-primary">Email</p>
                <a href={`mailto:${email}`} class="text-text-body hover:text-brand-forest-green transition-colors">
                  {email}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 bg-brand-natural-green">
                <Icon name="lucide:map-pin" width="20" height="20" class="text-white" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold mb-1 text-text-primary">Adres</p>
                <p class="text-text-body">
                  {address}
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 bg-brand-natural-green">
                <Icon name="lucide:clock" width="20" height="20" class="text-white" aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold mb-1 text-text-primary">Godziny pracy</p>
                <p class="text-text-body">{opening_hours}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- CTA box -->
      <div class="bg-gradient-to-br from-brand-forest-green to-brand-logo-green rounded-2xl p-8 text-white">
        <h3 class="text-2xl font-bold mb-4">
          Gotowy na zmianę?
        </h3>
        <p class="mb-6 opacity-90">
          Dołącz do setek zadowolonych klientów, którzy obniżyli koszty ogrzewania i przeszli na ekologiczne rozwiązania.
        </p>
        <a href={phoneHref} class="px-6 py-3 bg-white rounded-lg font-semibold text-brand-forest-green transition-all hover:shadow-lg">Umów konsultację</a>
      </div>
    </div>
  </div>
</section>
