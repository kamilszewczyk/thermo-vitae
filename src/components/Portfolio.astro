---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import { resolveImage } from "../lib/resolve-image";

const realizacje = await getCollection("realizacje");

const projects = await Promise.all(
    [...realizacje].map(async (item) => {
      const imageMeta = await resolveImage(item.data.image);
      let optimizedSrc = item.data.image;

      // If we got valid image metadata, run it through Astro's optimizer
      if (imageMeta) {
        try {
          const optimized = await getImage({
            src: imageMeta,
            width: 640,
            format: "webp",
          });
          optimizedSrc = optimized.src;
        } catch {
          // fallback to raw path
        }
      }

      return {
        slug: item.data.slug,
        title: item.data.title,
        showFullPage: item.data.show_full_page,
        latitude: item.data.gps_latitude,
        longitude: item.data.gps_longitude,
        shortDescription: item.data.short_description,
        image: optimizedSrc,
        status: item.data.status,
      };
    })
);
---

<section class="not-prose py-16 lg:py-24" id="realizacje">
  <!-- Section header -->
  <div class="text-center mb-16">
    <p class="uppercase tracking-wider text-sm text-text-inactive mb-4">
      NASZE REALIZACJE
    </p>
    <h2 class="text-3xl lg:text-4xl font-bold mb-4 text-text-primary">
      Portfolio projektów
    </h2>
    <p class="text-lg text-text-body max-w-2xl mx-auto">
      Zobacz przykłady naszych realizacji i przekonaj się o jakości wykonania
    </p>
  </div>

  <div class="relative w-full h-[70vh] lg:h-[80vh]">
    <div id="map" class="w-full h-full rounded-lg shadow-lg"></div>
    <div
        id="map-overlay"
        class="absolute inset-0 z-[999] flex items-center justify-center
             rounded-lg bg-black/45 text-white text-lg font-semibold
             pointer-events-none opacity-0 transition-opacity duration-300"
    >
      Użyj Ctrl + scroll, aby przybliżyć mapę
    </div>
  </div>

  <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <script define:vars={{ projects }}>
    import("https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js").then(
        (L) => {
          const map = L.map("map", {
            scrollWheelZoom: false,
            dragging: !L.Browser.mobile,
          }).setView([53.7536528,21.9673904], 9); // centered on Poland

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: "&copy; OpenStreetMap",
          }).addTo(map);

          projects.forEach((project) => {
            if (!project.latitude || !project.longitude) return;

            const popup = `
            <div style="min-width:200px;max-width:280px">
              ${
                project.image
                    ? `<img
                      src="${project.image}"
                      alt="${project.title}"
                      loading="lazy"
                      decoding="async"
                      style="width:100%;height:140px;object-fit:cover;border-radius:6px;margin-bottom:8px"
                    />`
                    : ""
            }
              <h3 style="margin:0 0 4px;font-size:1rem;font-weight:600">
                ${project.title}
              </h3>
              <p style="margin:0 0 8px;font-size:0.875rem;color:#4b5563">
                ${project.shortDescription ?? ""}
              </p>
              ${
                project.showFullPage
                    ? `<a
                href="/realizacje/${project.slug}"
                style="display:inline-block;padding:6px 14px;background:#2563eb;color:#fff;border-radius:6px;text-decoration:none;font-size:0.8rem;font-weight:500"
              >
                Zobacz więcej →
              </a>`
                    : ""
            }
            </div>
          `;

            L.marker([project.latitude, project.longitude])
                .addTo(map)
                .bindPopup(popup);
          });

          // --- Ctrl + scroll overlay ---
          const overlay = document.getElementById("map-overlay");
          const mapEl = document.getElementById("map");
          let hideTimeout;

          function showOverlay() {
            overlay.classList.add("opacity-100");
            overlay.classList.remove("opacity-0");
            clearTimeout(hideTimeout);
            hideTimeout = setTimeout(() => {
              overlay.classList.remove("opacity-100");
              overlay.classList.add("opacity-0");
            }, 1500);
          }

          mapEl.addEventListener(
              "wheel",
              (e) => {
                if (e.ctrlKey || e.metaKey) {
                  e.preventDefault();
                  map.scrollWheelZoom.enable();
                  setTimeout(() => map.scrollWheelZoom.disable(), 400);
                } else {
                  showOverlay();
                }
              },
              { passive: false }
          );

          // --- Mobile: two-finger drag ---
          if (L.Browser.mobile) {
            overlay.textContent =
                "Użyj dwóch palców, aby przesunąć mapę";

            map.on("touchstart", (e) => {
              if (e.originalEvent.touches.length === 1) {
                map.dragging.disable();
                showOverlay();
              } else {
                map.dragging.enable();
              }
            });
          }
        }
    );
  </script>
</section>