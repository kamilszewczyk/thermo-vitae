---
import { Icon } from 'astro-icon/components'

export interface FeatureItem {
  number?: string
  icon?: string
  iconBackground?: string
  iconColor?: string
  title?: string
  description?: string
}

export interface Props {
  subtitle?: string
  title?: string
  description?: string
  featuresLink?: 'none' | 'line'
  features?: FeatureItem[]
}

const block = Astro.props

const subtitle = (block.subtitle || '').trim()
const title = (block.title || '').trim()
const description = (block.description || '').trim()
const features = (block.features ?? []).slice(0, 4)
const featuresLink = block.featuresLink ?? 'none'

const featureCount = Math.min(Math.max(features.length, 1), 4)
const gridColsClassByCount = [
  'md:grid-cols-1 lg:grid-cols-1',
  'md:grid-cols-2 lg:grid-cols-2',
  'md:grid-cols-3 lg:grid-cols-3',
  'md:grid-cols-4 lg:grid-cols-4',
]
const gridColsClass = gridColsClassByCount[featureCount - 1]

const hasText = Boolean(subtitle || title || description)
const hasFeatures = features.length > 0
---
<section class="not-prose py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {hasText && (
      <div class="text-center mb-16">
        {subtitle && (
          <p class="uppercase tracking-wider text-sm text-text-inactive mb-4">
            {subtitle}
          </p>
        )}
        {title && (
          <h2 class="text-3xl lg:text-4xl font-bold mb-4 text-text-primary">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-lg text-text-body max-w-2xl mx-auto">
            {description}
          </p>
        )}
      </div>
    )}

    {hasFeatures && (
      <div class="relative">
        {featuresLink === 'line' && (
          <div
            class="hidden lg:block absolute top-20 left-0 right-0 h-0.5 bg-accent"
            style="margin-left:5%; margin-right:5%"
          ></div>
        )}

        <div class:list={['grid gap-8 relative', gridColsClass]}>
          {features.map((feature) => {
            const number = (feature.number || '').trim()
            const icon = (feature.icon || '').trim()
            const iconBackground =
              (feature.iconBackground || '').trim() || 'bg-brand-natural-green'
            const iconColor = (feature.iconColor || '').trim() || 'text-white'
            const itemTitle = (feature.title || '').trim()
            const itemDescription = (feature.description || '').trim()

            return (
              <div class="relative">
                <div class="bg-card rounded-2xl p-8 border-2 border-border hover:border-brand-natural-green transition-colors h-full">
                  <div class="flex flex-col items-center lg:items-start text-center lg:text-left h-full">
                    {(number || icon) && (
                      <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
                        {number && (
                          <div class="w-16 h-16 rounded-full flex items-center justify-center bg-brand-forest-green">
                            <span class="text-white text-2xl font-bold">{number}</span>
                          </div>
                        )}

                        {icon && (
                          <div
                            class:list={[
                              'w-14 h-14 rounded-xl flex items-center justify-center',
                              iconBackground,
                            ]}
                          >
                            <Icon
                              name={icon}
                              width="28"
                              height="28"
                              class:list={['text-white', iconColor]}
                              aria-hidden="true"
                            />
                          </div>
                        )}
                      </div>
                    )}

                    {itemTitle && (
                      <h3 class="text-xl font-bold mb-3 text-text-primary">
                        {itemTitle}
                      </h3>
                    )}
                    {itemDescription && (
                      <p class="text-text-body leading-relaxed">
                        {itemDescription}
                      </p>
                    )}
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </div>
    )}
  </div>
</section>
