---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/resolve-image";

type TrustIndicator = { value?: string; label?: string };

export interface Props {
    subtitle?: string;
    title?: string;
    description?: string;
    ctas?: any[];
    trustIndicators?: { value?: string; label?: string }[];
    image?: string | null;
    imageAlt?: string;
    imageSide?: "left" | "right";
    badgeEnabled?: boolean;
    badgeTitle?: string;
    badgeSubtitle?: string;
    badgePosition?: "top-left" | "top-right" | "bottom-left" | "bottom-right";
}

const block = Astro.props;

const subtitle = (block.subtitle || "").trim();
const title = (block.title || "").trim();
const description = (block.description || "").trim();
const trust = (block.trustIndicators ?? []).slice(0, 3);

const hasText =
    Boolean(subtitle) || Boolean(title) || Boolean(description) || trust.length > 0;

const imageMeta =  await resolveImage(block?.image);
const hasImage = Boolean(imageMeta);

const imageAlt = (block.imageAlt || "Hero image").trim();
const imageSide = block.imageSide ?? "right";

const isTwoCol = hasText && hasImage;
const imageFirst = isTwoCol && imageSide === "left";

const badgeEnabled = block.badgeEnabled !== false;
const hasBadge =
    hasImage &&
    badgeEnabled &&
    (block.badgeTitle?.trim() || block.badgeSubtitle?.trim());

const badgePosition = block.badgePosition ?? "bottom-left";

const badgePositionClass: Record<NonNullable<Hero["badgePosition"]>, string> =
    {
      "top-left": "top-6 left-6",
      "top-right": "top-6 right-6",
      "bottom-left": "bottom-6 left-6",
      "bottom-right": "bottom-6 right-6",
    };
---

<section class="bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div
        class:list={[
          "grid gap-12 items-center",
          isTwoCol ? "lg:grid-cols-2" : "grid-cols-1",
        ]}
    >
      {hasText && (
          <div class:list={[imageFirst ? "lg:order-2" : "lg:order-1", "space-y-8"]}>
            <div class="space-y-4">
              {subtitle && (
                  <p class="uppercase tracking-wider text-sm text-text-inactive">
                    {subtitle}
                  </p>
              )}

              {title && (
                  <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight text-text-primary">
                    {title}
                  </h1>
              )}

              {description && (
                  <p class="text-lg text-text-body leading-relaxed">{description}</p>
              )}
            </div>

            {trust.length > 0 && (
                <div class="flex flex-wrap gap-8 pt-4">
                  {trust.map((item) => {
                    const v = (item.value || "").trim();
                    const l = (item.label || "").trim();
                    if (!v && !l) return null;

                    return (
                        <div>
                          {v && (
                              <p class="text-3xl font-bold text-brand-forest-green">
                                {v}
                              </p>
                          )}
                          {l && <p class="text-sm text-text-inactive">{l}</p>}
                        </div>
                    );
                  })}
                </div>
            )}
          </div>
      )}

      {hasImage && imageMeta && (
          <div class:list={[imageFirst ? "lg:order-1" : "lg:order-2", "relative"]}>
            <div class="rounded-2xl overflow-hidden shadow-2xl">
              <Image
                  src={imageMeta}
                  alt={imageAlt}
                  class="w-full h-[500px] object-cover"
                  widths={[640, 960, 1080, 1400]}
                  sizes={isTwoCol ? "(min-width: 1024px) 50vw, 100vw" : "100vw"}
                  loading="lazy"
              />
            </div>

            {hasBadge && (
                <div
                    class:list={[
                      "absolute bg-card rounded-xl shadow-xl p-6 hidden lg:block",
                      badgePositionClass[badgePosition],
                    ]}
                >
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center bg-brand-natural-green">
                      <span class="text-white text-xl font-bold">✓</span>
                    </div>
                    <div>
                      {block.badgeTitle?.trim() && (
                          <p class="font-semibold text-text-primary">
                            {block.badgeTitle.trim()}
                          </p>
                      )}
                      {block.badgeSubtitle?.trim() && (
                          <p class="text-sm text-text-inactive">
                            {block.badgeSubtitle.trim()}
                          </p>
                      )}
                    </div>
                  </div>
                </div>
            )}
          </div>
      )}
    </div>
  </div>
</section>