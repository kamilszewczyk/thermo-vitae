---
// No props for now; static content translated from React component
---
<section class="bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left side - Text content -->
      <div class="space-y-8">
        <div class="space-y-4">
          <p class="uppercase tracking-wider text-sm text-text-inactive">
            Odnawialne źródła energii
          </p>
          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight text-text-primary">
            Profesjonalne systemy grzewcze dla Twojego domu
          </h1>
          <p class="text-lg text-text-body leading-relaxed">
            Specjalizujemy się w projektowaniu i instalacji nowoczesnych pomp ciepła.
            15 lat doświadczenia, setki zadowolonych klientów i gwarancja najwyższej jakości.
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#kontakt" class="px-8 py-4 rounded-lg font-semibold text-white bg-brand-forest-green transition-all hover:shadow-lg text-center">
            Darmowa wycena
          </a>
          <a href="#realizacje" class="px-8 py-4 rounded-lg font-semibold border-2 border-brand-forest-green text-brand-forest-green transition-all hover:bg-background-gray text-center">
            Zobacz realizacje
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap gap-8 pt-4">
          <div>
            <p class="text-3xl font-bold text-brand-forest-green">15+</p>
            <p class="text-sm text-text-inactive">Lat doświadczenia</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-brand-forest-green">500+</p>
            <p class="text-sm text-text-inactive">Instalacji</p>
          </div>
          <div>
            <p class="text-3xl font-bold text-brand-forest-green">98%</p>
            <p class="text-sm text-text-inactive">Zadowolonych klientów</p>
          </div>
        </div>
      </div>

      <!-- Right side - Image -->
      <div class="relative">
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <img
            src="https://images.unsplash.com/photo-1606983773367-8f93e7bbad8d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxoYXBweSUyMGZhbWlseSUyMHdhcm0lMjBob21lJTIwaW50ZXJpb3J8ZW58MXx8fHwxNzY5OTM4ODQ3fDA&ixlib=rb-4.1.0&q=80&w=1080"
            alt="Modern heating system"
            class="w-full h-[500px] object-cover"
          />
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-6 -left-6 bg-card rounded-xl shadow-xl p-6 hidden lg:block">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center bg-brand-natural-green">
              <span class="text-white text-xl font-bold">✓</span>
            </div>
            <div>
              <p class="font-semibold text-text-primary">Certyfikowane</p>
              <p class="text-sm text-text-inactive">Instalacje</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
