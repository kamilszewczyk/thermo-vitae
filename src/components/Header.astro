---
import MenuLinks from "./MenuLinks.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { reader } from "../lib/keystatic";

const header = await reader.singletons.header.read();
const phone = header?.phone ?? "+48 123 456 789";
const phoneHref = `tel:${phone.replace(/\s+/g, '')}`;
const logoAlt = header?.logoAlt ?? "Thermo Vitae";

import { resolveImage } from "../lib/resolve-image";
const logoImage = await resolveImage(header?.logo);
---

<header class="bg-background border-b border-border sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        {logoImage ? (
            <Image
                src={logoImage}
                alt={logoAlt}
                height={48}
                class="h-12 w-auto"
            />
        ) : (
            <!-- Fallback: text logo if no image uploaded yet -->
            <div class="relative">
            <span class="text-3xl font-bold text-brand-logo-green">
              Thermo
            </span>
              <span class="text-3xl font-bold text-brand-thermo-red">
              {" "}Vitae
            </span>
            </div>
        )}
      </a>

      <!-- Navigation (desktop) -->
      <MenuLinks class="hidden md:flex items-center gap-8" linkClass="text-text-body hover:text-brand-forest-green transition-colors" />

      <!-- CTA Buttons -->
      <div class="flex items-center gap-4">
        <a href="{phoneHref}" class="hidden lg:flex items-center gap-2 text-text-body hover:text-brand-forest-green transition-colors">
          <Icon name="lucide:phone" width="18" height="18" aria-hidden="true" />
          <span>{phone}</span>
        </a>
        <button id="mobile-menu-button" class="md:hidden p-2 text-text-body" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
          <Icon name="lucide:menu" width="24" height="24" aria-hidden="true" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-background">
    <MenuLinks class="px-4 py-4 space-y-2" linkClass="block px-2 py-2 rounded-md text-text-body hover:text-brand-forest-green hover:bg-accent transition-colors" />
  </div>

  <script>
    // Accessible toggle behavior for mobile menu
    const btn = document.getElementById('mobile-menu-button');
    const panel = document.getElementById('mobile-menu');
    if (btn && panel) {
      const toggle = () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const next = !expanded;
        btn.setAttribute('aria-expanded', String(next));
        panel.classList.toggle('hidden', !next);
      };
      btn.addEventListener('click', toggle);

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
          btn.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
          btn.focus();
        }
      });

      // Close when clicking a link in the panel
      panel.addEventListener('click', (e) => {
        const target = e.target;
        if (target instanceof HTMLElement && target.tagName === 'A') {
          btn.setAttribute('aria-expanded', 'false');
          panel.classList.add('hidden');
        }
      });
    }
  </script>
</header>
