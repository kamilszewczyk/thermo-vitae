---
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";

interface Props {
  src?: string;
  alt?: string;
  title?: string;
}

const { src = "", alt = "", title = "" } = Astro.props as Props;
const imageMeta = await resolveImage(src);
const fallbackAlt = (alt || title || "").trim();
---

{imageMeta ? (
  <Image
    src={imageMeta}
    alt={fallbackAlt}
    title={title || undefined}
    class="my-6 w-full h-auto rounded-xl"
    widths={[640, 960, 1280, 1600]}
    sizes="(min-width: 1024px) 1024px, 100vw"
    loading="lazy"
    decoding="async"
  />
) : (
  <img
    src={src}
    alt={fallbackAlt}
    title={title || undefined}
    class="my-6 w-full h-auto rounded-xl"
    loading="lazy"
    decoding="async"
  />
)}

