# Public site (default)
SITE_MODE=production

# Editor mode (enable Keystatic UI/integration)
# SITE_MODE=editor

# Used only for editor builds on hosting platforms.
# Supported in current draft: vercel
HOSTING_PROVIDER=none

# Optional gate for editor environment.
# If both are set and SITE_MODE=editor, all requests require basic auth.
# EDITOR_BASIC_AUTH_USER=editor
# EDITOR_BASIC_AUTH_PASSWORD=change-me

# Keystatic storage mode: local | github
PUBLIC_KEYSTATIC_STORAGE_KIND=local

# Required when PUBLIC_KEYSTATIC_STORAGE_KIND=github
# Format: owner/repo
# PUBLIC_KEYSTATIC_GITHUB_REPO=kamilszewczyk/thermo-vitae

# GitHub OAuth app credentials used by Keystatic API routes.
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=

# Session secret used to sign Keystatic auth cookies.
# Generate a long random value (32+ chars).
# KEYSTATIC_SECRET=

# Warn editors when Keystatic is running on a protected branch.
# Set to false to disable banner + confirmation dialog.
# KEYSTATIC_MASTER_WARNING=true

# Protected branch name that should show warning (default: master).
# KEYSTATIC_PROTECTED_BRANCH=master

# Optional explicit branch override for environments where branch name
# is not exposed as VERCEL_GIT_COMMIT_REF / GITHUB_REF_NAME.
# KEYSTATIC_CURRENT_BRANCH=

